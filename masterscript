    echo -e "${BOLD}${BLUE}║  $1${NC}"
    echo -e "${BOLD}${BLUE}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

step() {
    echo -e "${BOLD}${CYAN}▶ STEP $1: $2${NC}"
    echo -e "${YELLOW}   Press ENTER to continue...${NC}"
    read
}

success() { echo -e "${GREEN}  ✅ $1${NC}"; }
info()    { echo -e "${CYAN}  ℹ  $1${NC}"; }
warn()    { echo -e "${YELLOW}  ⚠  $1${NC}"; }
running() { echo -e "${MAGENTA}  ⚙  $1${NC}"; }

ssh_ubuntu() {
    sshpass -p "$UBUNTU_PASS" ssh -o StrictHostKeyChecking=no \
        -o ConnectTimeout=10 "$UBUNTU_USER@$UBUNTU_IP" "$1"
}

ssh_ubuntu_retry() {
    local CMD="$1"
    local TRIES=0
    while true; do
        TRIES=$((TRIES+1))
        info "SSH attempt $TRIES → $UBUNTU_IP"
        if sshpass -p "$UBUNTU_PASS" ssh -o StrictHostKeyChecking=no \
            -o ConnectTimeout=10 "$UBUNTU_USER@$UBUNTU_IP" "$CMD" 2>/dev/null; then
            success "SSH connected!"
            break
        else
            warn "SSH failed — retry in 5 seconds..."
            sleep 5
        fi
    done
}

scp_retry() {
    local SRC="$1"
    local DST="$2"
    local TRIES=0
    while true; do
        TRIES=$((TRIES+1))
        info "SCP attempt $TRIES — copying $SRC"
        if sshpass -p "$UBUNTU_PASS" scp -o StrictHostKeyChecking=no \
            -o ConnectTimeout=15 "$UBUNTU_USER@$UBUNTU_IP:$SRC" "$DST" 2>/dev/null; then
            success "File copied: $DST"
            break
        else
            warn "SCP failed — retry in 5 seconds..."
            sleep 5
        fi
    done
}

# ── Check sshpass installed ───────────────────────────────────
if ! command -v sshpass &>/dev/null; then
    warn "sshpass not found — installing..."
    brew install sshpass 2>/dev/null || {
        warn "brew install failed. Manual SSH use hoga."
        ssh_ubuntu() { ssh "$UBUNTU_USER@$UBUNTU_IP" "$1"; }
